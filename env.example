# ============================================================
# ENVIRONMENT VARIABLES — TEMPLATE
# ============================================================
# This is the TEMPLATE file. It is safe to commit to GitHub.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to GitHub (it's in .gitignore)
# ============================================================


# ------------------------------------------------------------
# WEBFLOW API
# ------------------------------------------------------------

# Your Webflow API Token
# Get it from: Webflow Dashboard → Account Settings → Integrations → API Access
# Docs: https://developers.webflow.com/data/reference/authorization
WEBFLOW_API_TOKEN=your_api_token_here

# Your Webflow Site ID
# Get it from: Webflow → Site Settings → General → scroll to bottom → Site ID
WEBFLOW_SITE_ID=your_site_id_here


# ------------------------------------------------------------
# COLLECTION IDs
# ------------------------------------------------------------
# Add a line here for each CMS Collection you create in Webflow.
# Get IDs from: Webflow CMS panel → right-click collection → Copy Collection ID
# [CUSTOMIZE] Replace these examples with your real collections:

# WEBFLOW_COLLECTION_BLOG_POSTS=your_collection_id_here
# WEBFLOW_COLLECTION_TEAM_MEMBERS=your_collection_id_here
# WEBFLOW_COLLECTION_PROJECTS=your_collection_id_here


# ------------------------------------------------------------
# OPTIONAL: EXTERNAL DATA SOURCES
# ------------------------------------------------------------
# If your CMS scripts pull data from external sources (Airtable,
# Notion, Google Sheets, etc.), add those keys here.

# AIRTABLE_API_KEY=your_key_here
# AIRTABLE_BASE_ID=your_base_id_here

# NOTION_API_KEY=your_key_here

